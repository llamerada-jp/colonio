{
  "port": 8080,
  "certFile": "../../localhost.crt",
  "keyFile": "../../localhost.key",
  "useTcp": true,
  "documentRoot": "../dist",
  "docOverrides": {
    "/colonio.js": "../../output/"
  },
  "cluster": {
    "revision": 20240317.1,
    "sessionTimeout": "30s",
    "pollingTimeout": "10s",
    "iceServers": [
      {
        "urls": [
          "stun:stun.l.google.com:19302"
        ]
      }
    ],
    "keepaliveInterval": "10s",
    "bufferInterval": "10ms",
    "webrtcPacketBaseBytes": 16384,
    "coordSystem2D": {
      "type": "sphere",
      "radius": 6378137
    },
    "spread": {
      "cacheTime": 100
    },
    "routing": {
      "forceUpdateTimes": 20,
      "updatePeriod": 500
    }
  },
  "seedPath": "/seed"
}